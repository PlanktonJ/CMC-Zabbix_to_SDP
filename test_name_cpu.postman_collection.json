{
  "info": {
    "name": "Test: name + udf_cpu sync",
    "description": "3-step flow: (1) pick a host group -> (2) get all hosts in group -> (3) get CPU for all those hosts. Run in order after Login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "zabbix_url",  "value": "" },
    { "key": "sdp_url",     "value": "http://YOUR_SDP_URL/api/v3/ci" },
    { "key": "sdp_api_key", "value": "YOUR_SDP_API_KEY" },
    { "key": "auth_token",  "value": "" },
    { "key": "group_id",    "value": "" },
    { "key": "host_ids",    "value": "[]" },
    { "key": "ci_id",       "value": "" }
  ],
  "item": [
    {
      "name": "ZABBIX",
      "item": [
        {
          "name": "0. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "if (body.result) {",
                  "    pm.collectionVariables.set('auth_token', body.result);",
                  "    console.log('[OK] auth_token saved.');",
                  "} else {",
                  "    console.error('[FAIL] Login error:', JSON.stringify(body.error));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{zabbix_url}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"user.login\",\n  \"params\": {\n    \"user\": \"YOUR_ZABBIX_USER\",\n    \"password\": \"YOUR_ZABBIX_PASSWORD\"\n  },\n  \"auth\": null,\n  \"id\": 1\n}"
            }
          }
        },
        {
          "name": "STEP 1 — hostgroup.get (choose a group)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "var groups = body.result || [];",
                  "",
                  "console.log('====================================================');",
                  "console.log('  AVAILABLE HOST GROUPS — pick one and set group_id');",
                  "console.log('====================================================');",
                  "groups.forEach(function(g) {",
                  "    console.log('  groupid: ' + g.groupid + '  |  name: ' + g.name);",
                  "});",
                  "console.log('====================================================');",
                  "console.log('  >> Go to collection Variables tab');",
                  "console.log('  >> Set group_id = <groupid from list above>');",
                  "console.log('  >> Then run STEP 2');",
                  "console.log('====================================================');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{zabbix_url}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"hostgroup.get\",\n  \"params\": {\n    \"output\": [\"groupid\", \"name\"],\n    \"real_hosts\": true,\n    \"sortfield\": \"name\"\n  },\n  \"auth\": \"{{auth_token}}\",\n  \"id\": 2\n}"
            }
          }
        },
        {
          "name": "STEP 2 — host.get by group_id (saves all hostids)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var gid = pm.collectionVariables.get('group_id');",
                  "if (!gid) {",
                  "    console.error('[ERROR] group_id is empty. Run STEP 1 first, then set group_id in Variables tab.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "var hosts = body.result || [];",
                  "",
                  "if (hosts.length === 0) {",
                  "    console.error('[ERROR] No hosts found for group_id:', pm.collectionVariables.get('group_id'));",
                  "} else {",
                  "    var hostids = hosts.map(function(h) { return h.hostid; });",
                  "    pm.collectionVariables.set('host_ids', JSON.stringify(hostids));",
                  "",
                  "    console.log('====================================================');",
                  "    console.log('  HOSTS IN GROUP (' + hosts.length + ' total)');",
                  "    console.log('====================================================');",
                  "    hosts.forEach(function(h) {",
                  "        var status = h.status === '0' ? 'monitored' : 'not_monitored';",
                  "        console.log('  hostid: ' + h.hostid + '  |  host: ' + h.host + '  |  ' + status);",
                  "    });",
                  "    console.log('====================================================');",
                  "    console.log('  [OK] host_ids saved (' + hostids.length + ' hosts). Run STEP 3.');",
                  "    console.log('====================================================');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{zabbix_url}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"host.get\",\n  \"params\": {\n    \"output\": [\"hostid\", \"host\", \"name\", \"status\"],\n    \"groupids\": [\"{{group_id}}\"]\n  },\n  \"auth\": \"{{auth_token}}\",\n  \"id\": 3\n}"
            }
          }
        },
        {
          "name": "STEP 3 — item.get cpu for all hosts in group",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var ids = pm.collectionVariables.get('host_ids');",
                  "if (!ids || ids === '[]') {",
                  "    console.error('[ERROR] host_ids is empty. Run STEP 2 first.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "var items = body.result || [];",
                  "",
                  "if (items.length === 0) {",
                  "    console.warn('[WARN] No cpu items found for any host in this group.');",
                  "    console.warn('       These hosts may not have system.cpu.num[snmp] or system.cpu.num items.');",
                  "} else {",
                  "    console.log('====================================================');",
                  "    console.log('  CPU RESULTS (-> udf_cpu in SDP)');",
                  "    console.log('====================================================');",
                  "    items.forEach(function(item) {",
                  "        console.log('  hostid: ' + item.hostid + '  |  key: ' + item.key_ + '  |  udf_cpu: ' + item.lastvalue);",
                  "    });",
                  "    console.log('====================================================');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{zabbix_url}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"item.get\",\n  \"params\": {\n    \"output\": [\"hostid\", \"key_\", \"lastvalue\"],\n    \"hostids\": {{host_ids}},\n    \"filter\": { \"key_\": [\"system.cpu.num[snmp]\", \"system.cpu.num\"] }\n  },\n  \"auth\": \"{{auth_token}}\",\n  \"id\": 4\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{zabbix_url}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"user.logout\",\n  \"params\": [],\n  \"auth\": \"{{auth_token}}\",\n  \"id\": 5\n}"
            }
          }
        }
      ]
    },
    {
      "name": "SDP",
      "item": [
        {
          "name": "SDP — search CI by hostname",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "var list = body['cmdb_server_new'] || [];",
                  "if (list.length > 0) {",
                  "    pm.collectionVariables.set('ci_id', list[0].id);",
                  "    console.log('[OK] CI found — id:', list[0].id, '| current name:', list[0].name);",
                  "    console.log('     udf_hostname:', list[0].udf_fields && list[0].udf_fields.udf_hostname);",
                  "    console.log('     udf_cpu:', list[0].udf_fields && list[0].udf_fields.udf_cpu);",
                  "} else {",
                  "    console.warn('[WARN] No CI found for this hostname.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "technician_key", "value": "{{sdp_api_key}}" }],
            "url": {
              "raw": "{{sdp_url}}/cmdb_server_new",
              "host": ["{{sdp_url}}"],
              "path": ["cmdb_server_new"],
              "query": [
                {
                  "key": "input_data",
                  "value": "{\"list_info\":{\"row_count\":1,\"start_index\":1,\"search_criteria\":[{\"field\":\"udf_hostname\",\"condition\":\"is\",\"value\":\"REPLACE_WITH_ZABBIX_host_VALUE\"}]}}"
                }
              ]
            }
          }
        },
        {
          "name": "SDP — PUT update name + udf_cpu",
          "description": "Sends only name and udf_cpu. All other SDP-owned fields are untouched.",
          "request": {
            "method": "PUT",
            "header": [{ "key": "technician_key", "value": "{{sdp_api_key}}" }],
            "url": "{{sdp_url}}/cmdb_server_new/{{ci_id}}",
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "input_data",
                  "value": "{\n  \"name\": \"REPLACE_WITH_ZABBIX_host_VALUE\",\n  \"udf_fields\": {\n    \"udf_cpu\": \"REPLACE_WITH_CPU_COUNT\"\n  }\n}"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
