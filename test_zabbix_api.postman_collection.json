{
  "info": {
    "name": "Zabbix API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }]
  },
  "variable": [
    {
      "key": "zabbix_url",
      "value": "http://172.28.236.10:8080/api_jsonrpc.php"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "host_id_1",
      "value": ""
    },
    {
      "key": "host_id_2",
      "value": ""
    },
    {
      "key": "group_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. host.get (all hosts)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{zabbix_url}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"host.get\",\n  \"params\": {\n    \"output\": [\"hostid\", \"host\", \"name\", \"status\", \"description\"],\n    \"selectInterfaces\": [\"ip\", \"dns\", \"type\", \"main\", \"useip\"],\n    \"selectGroups\": [\"name\"]\n  },\n  \"id\": 2\n}"
        }
      }
    },
    {
      "name": "2. item.get (monitoring items)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{zabbix_url}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"item.get\",\n  \"params\": {\n    \"output\": [\"hostid\", \"name\", \"key_\", \"lastvalue\", \"units\"],\n    \"hostids\": [\"{{host_id_1}}\", \"{{host_id_2}}\"]\n  },\n  \"id\": 3\n}"
        }
      }
    },
    {
      "name": "3. hostgroup.get (all groups with hosts)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{zabbix_url}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"hostgroup.get\",\n  \"params\": {\n    \"output\": [\"groupid\", \"name\"],\n    \"real_hosts\": true,\n    \"sortfield\": \"name\"\n  },\n  \"id\": 4\n}"
        }
      }
    },
    {
      "name": "4. host.get (by group)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{zabbix_url}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"host.get\",\n  \"params\": {\n    \"output\": [\"hostid\", \"host\", \"name\", \"status\", \"description\"],\n    \"selectInterfaces\": [\"ip\", \"dns\", \"type\", \"main\", \"useip\"],\n    \"selectGroups\": [\"name\"],\n    \"groupids\": [\"{{group_id}}\"]\n  },\n  \"id\": 5\n}"
        }
      }
    }
  ]
}
